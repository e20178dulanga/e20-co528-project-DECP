# Feed Service - Port must differ from Auth Service (5000)
PORT=5001

# Same MongoDB instance as Auth Service (separate collection: posts)
MONGO_URI=mongodb://localhost:27017/decp

# MUST match JWT_SECRET in backend/.env exactly
JWT_SECRET=replace_this_with_a_long_random_secret

# Max upload file size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760
