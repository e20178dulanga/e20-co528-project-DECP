# Jobs Service — Port must differ from Auth (5000) and Feed (5001)
PORT=5002

# Same MongoDB instance as other services — replace with Atlas URI in production
MONGO_URI=mongodb://localhost:27017/decp

# MUST match JWT_SECRET in backend/.env and feed-service/.env exactly
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# CORS — set to your Vercel frontend URL in production (no trailing slash)
FRONTEND_URL=https://decp-frontend.vercel.app
