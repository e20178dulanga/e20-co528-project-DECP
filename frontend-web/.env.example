# Frontend — Vite Environment Variables
# Copy this file to .env.local for local dev (values below are the localhost defaults)
# For Vercel: set these in the Vercel project dashboard under Settings > Environment Variables

# Backend service URLs — set to your Render.com service URLs in production
VITE_AUTH_URL=https://decp-backend-auth.onrender.com/api
VITE_FEED_URL=https://decp-feed.onrender.com/api
VITE_JOBS_URL=https://decp-jobs.onrender.com/api
VITE_EVENTS_URL=https://decp-events.onrender.com/api
