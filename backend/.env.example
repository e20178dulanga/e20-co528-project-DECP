# Server
PORT=5000

# MongoDB — replace with your MongoDB Atlas connection string in production
MONGO_URI=mongodb://localhost:27017/decp

# JWT — MUST be the same value across all 4 backend services
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# CORS — set to your Vercel frontend URL in production (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app
